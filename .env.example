# REQUIRED
OPENSEARCH_INITIAL_ADMIN_PASSWORD=ChangeMe_UseASecretVaultOrAtLeastStrongPassword!

# Optional naming
OPENSEARCH_CLUSTER_NAME=ndr-central
OPENSEARCH_NODE_NAME=opensearch-node1

# JVM sizing (tune per VM)
OPENSEARCH_JAVA_OPTS="-Xms4g -Xmx4g"

# Your "real admin" you want to create via REST after bootstrap
NDR_ADMIN_USERNAME=ndr_admin
NDR_ADMIN_PASSWORD=ChangeMe_StrongPassword!
